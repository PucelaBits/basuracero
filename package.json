{
  "name": "basura-cero",
  "version": "2.0.2",
  "description": "Sistema de reporte de incidencias urbanas",
  "main": "src/server/server.js",
  "scripts": {
    "start": "node scripts/prepareAdminActivation.js && npm run migrate && node src/server/server.js",
    "dev:server": "node scripts/prepareAdminActivation.js && nodemon src/server/server.js",
    "dev:client": "node scripts/generateManifest.js public && vite",
    "build": "vite build && node scripts/generateManifest.js dist && npm run copy-index",
    "copy-index": "cp dist/index.html dist/200.html",
    "incidencia": "node scripts/gestionarIncidencias.js",
    "tipos": "node scripts/gestionarTipos.js",
    "rellenar-barrios": "node scripts/rellenarBarrios.js",
    "migrar-imagenes": "node scripts/migrarImagenes.js",
    "borrar-reportes-solucion": "node scripts/borrarReportesSolucion.js",
    "rellenar-direcciones": "node scripts/rellenarDirecciones.js",
    "asignar-imagen": "node scripts/asignarImagen.js",
    "import-incidencias": "node scripts/importarIncidencias.js",
    "solucionar-antiguas": "node scripts/solucionarAntiguas.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "migrate": "node scripts/runMigrations.js",
    "admin:bootstrap": "npm run migrate && node scripts/bootstrapAdmin.js",
    "lint": "eslint . --max-warnings=200"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@unhead/vue": "^2.1.15",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.19.0",
    "feed": "^4.2.2",
    "friendly-challenge": "^0.9.20",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "multer": "^2.2.0",
    "papaparse": "^5.5.4",
    "sharp": "^0.34.5",
    "sqlite3": "^6.0.1",
    "vue": "^3.5.39",
    "vue-router": "^4.4.5",
    "vuetify": "^3.12.10"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.8",
    "eslint": "^9.39.5",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0",
    "vite": "^8.1.4"
  },
  "overrides": {
    "follow-redirects": "1.16.0",
    "qs": "^6.14.1",
    "tar": "^7.5.8",
    "minimatch": "^10.2.1",
    "path-to-regexp": "0.1.13"
  }
}
